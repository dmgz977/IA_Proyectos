# === Google Calendar API ===
GOOGLE_CLIENT_ID=tu_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_client_secret_aqui
GOOGLE_REFRESH_TOKEN=tu_refresh_token_aqui
GOOGLE_CALENDAR_ID=primary

# === Comportamiento del Scheduler ===
# Frecuencia de escaneo del calendario (en minutos)
SCAN_INTERVAL_MINUTES=15
# Minutos de anticipación para enviar el recordatorio
REMINDER_MINUTES_BEFORE=15
# Cuántas horas hacia adelante consultar en cada ciclo
LOOKAHEAD_HOURS=2

# === Display ===
# Zona horaria para mostrar las horas en las notificaciones
TIMEZONE=America/Bogota

# === WhatsApp ===
# Ruta donde se guarda la sesión de WhatsApp (excluir de Git)
WHATSAPP_SESSION_PATH=./whatsapp-session
